# Copy this file to .env and fill in your values
OPENWEATHER_API_KEY=your_api_key_here

# Compatibility aliases used by this app:
# - OPENAI_API_KEY is treated as an OpenRouter key.
# - ANTHROPIC_API_KEY is treated as a Hugging Face token.
OPENAI_API_KEY=your_openrouter_key_here
ANTHROPIC_API_KEY=your_huggingface_token_here

# Optional explicit names; these override the compatibility aliases above.
OPENROUTER_API_KEY=
HUGGINGFACE_API_KEY=
OPENROUTER_MODEL=openrouter/auto
HUGGINGFACE_MODEL=openai/gpt-oss-120b:fastest
